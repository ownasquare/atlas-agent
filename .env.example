# Model. Install the matching optional provider integration when not using OpenAI.
ATLAS_MODEL=openai:gpt-4.1-mini
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Search. Tavily is preferred; DDGS is the zero-key fallback.
TAVILY_API_KEY=

# Durable local state.
ATLAS_DATA_DIR=.atlas/data
ATLAS_WORKSPACE_DIR=.atlas/workspace
ATLAS_MEMORY_ENABLED=true

# Safety and execution budgets.
ATLAS_REQUIRE_CODE_APPROVAL=true
ATLAS_REQUIRE_OVERWRITE_APPROVAL=true
# Safe default. Set to docker only after Docker is installed and running.
ATLAS_CODE_EXECUTION_BACKEND=disabled
ATLAS_MAX_AGENT_ITERATIONS=8
ATLAS_THREAD_LOCK_TIMEOUT_SECONDS=120
ATLAS_MAX_REVIEW_CYCLES=2
ATLAS_MAX_TOOL_OUTPUT_CHARS=12000
